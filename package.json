{
  "name": "codemod-clean",
  "version": "2.4.0",
  "description": "A codemod tool to clean up console and unused variables and unused imports in JavaScript code.",
  "main": "./bin/cli.js",
  "_moduleAliases": {
    "@": "./src",
    "@core": "./src/core",
    "@utils": "./src/utils",
    "@constants": "./src/constants",
    "@analyze": "./src/analyze"
  },
  "scripts": {
    "version:patch": "standard-version --release-as patch --skip.tag",
    "version:minor": "standard-version --release-as minor --skip.tag",
    "version:major": "standard-version --release-as major --skip.tag",
    "release": "node scripts/release.js",
    "release:version": "node scripts/release.js --version-only",
    "release:publish": "node scripts/release.js --publish-only",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "bin": {
    "codemod-clean": "./bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "package.json",
    "README.md"
  ],
  "keywords": [
    "codemod",
    "clean",
    "console",
    "unused-variables",
    "unused-imports",
    "ast",
    "babel"
  ],
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@vue/compiler-dom": "^3.5.35",
    "@vue/compiler-sfc": "^3.5.34",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dayjs": "^1.11.21",
    "fs-extra": "^11.3.5",
    "globby": "^16.2.0",
    "module-alias": "^2.3.4",
    "postcss": "^8.5.15",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "postcss-selector-parser": "^7.1.1",
    "treeify": "^1.1.0"
  },
  "devDependencies": {
    "execa": "^9.6.1",
    "prompts": "^2.4.2",
    "semver": "^7.8.1",
    "standard-version": "^9.5.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/liyang0318/codemod-clean#readme",
  "bugs": {
    "url": "https://github.com/liyang0318/codemod-clean/issues"
  },
  "author": "liyang",
  "license": "ISC",
  "engines": {
    "node": ">=20.11.0"
  }
}
