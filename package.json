{
  "name": "codemod-clean",
  "version": "2.4.1",
  "description": "Monorepo-aware static analysis and codemod engine for JavaScript/TypeScript/Vue. Detect unused code, optimize imports, analyze dependency graphs, and identify architectural hotspots across packages.",
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "node bin/cli.js",
    "dev:prod": "node dist/cli.js",
    "preview": "node dist/cli.js",
    "build": "node scripts/build.js",
    "release": "node scripts/release.js",
    "release:version": "node scripts/release.js --version-only",
    "release:publish": "node scripts/release.js --publish-only",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "bin": {
    "codemod-clean": "./dist/cli.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codemod",
    "monorepo",
    "static-analysis",
    "dependency-graph",
    "unused-code",
    "unused-imports",
    "unused-variables",
    "unused-packages",
    "console-cleanup",
    "code-cleanup",
    "refactoring",
    "ast",
    "babel",
    "vue",
    "typescript",
    "javascript",
    "shared-packages",
    "architecture-analysis",
    "coupling-detection",
    "orphan-detection",
    "import-optimization"
  ],
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@vue/compiler-dom": "^3.5.35",
    "@vue/compiler-sfc": "^3.5.34",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dayjs": "^1.11.21",
    "fs-extra": "^11.3.5",
    "globby": "^16.2.0",
    "postcss": "^8.5.15",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "postcss-selector-parser": "^7.1.1",
    "treeify": "^1.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "execa": "^9.6.1",
    "prompts": "^2.4.2",
    "semver": "^7.8.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/liyang0318/codemod-clean#readme",
  "bugs": {
    "url": "https://github.com/liyang0318/codemod-clean/issues"
  },
  "author": "liyang",
  "license": "ISC",
  "engines": {
    "node": ">=20.11.0"
  }
}
